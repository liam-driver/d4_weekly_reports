# Ignore everything by default
*

# Keep this file
!.gitignore

# Allow directories
!core/
!weekly_reports/
!monthly_reports/
!traps_and_tripwires/
!mcp_server/
!.claude/
!templates/
!fonts/
!slides/

# Allow contents
!core/**
!weekly_reports/**
!monthly_reports/**
!traps_and_tripwires/**
!mcp_server/**
!.claude/**
!templates/**
!fonts/**
!slides/template.pptx

# Root-level files to keep
!requirements.txt
!README.*

# Override: always ignore these regardless of above rules
.claude/settings.local.json
secrets.json
creds.json
storage/
venv/
.venv/
__pycache__/
*.pyc
*.env
.env
