# Ignore everything by default
*

# Keep this file
!.gitignore

# Allow directories
!core/
!weekly_reports/
!monthly_reports/
!traps_and_tripwires/
!mcp_server/
!.claude/
!templates/
!fonts/
!slides/
!tests/
!storage/
!docs/

# Allow contents
!core/**
!weekly_reports/**
!monthly_reports/**
!traps_and_tripwires/**
!mcp_server/**
!.claude/**
!templates/**
!fonts/**
!slides/template.pptx
!tests/**
!docs/**

# Root-level files to keep
!requirements.txt
!README.*

# Override: always ignore these regardless of above rules
.claude/settings.local.json
secrets.json
creds.json
storage/*
!storage/dimension_config.json
venv/
.venv/
__pycache__/
*.pyc
*.env
.env
