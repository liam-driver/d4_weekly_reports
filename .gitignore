# Ignore everything by default
*

# Keep this file
!.gitignore

# Allow directories
!core/
!weekly_reports/
!mcp_server/
!.claude/
!templates/

# Allow contents
!core/**
!weekly_reports/**
!mcp_server/**
!.claude/**
!templates/**

# Root-level files to keep
!requirements.txt
!README.*

# Override: always ignore these regardless of above rules
secrets.json
creds.json
storage/
venv/
.venv/
__pycache__/
*.pyc
*.env
.env
